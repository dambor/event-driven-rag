# ============================================================================
# COS → Langflow Auto-Trigger Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Langflow Configuration (REQUIRED - Get from Langflow)
# ----------------------------------------------------------------------------
# LANGFLOW_URL: Your Langflow flow API endpoint
#   - Open your flow in Langflow → Click "API" button → Copy the endpoint URL
#   - Example: https://your-langflow-host/api/v1/run/abc123?stream=false
LANGFLOW_URL=https://your-langflow-host/api/v1/run/your-flow-id?stream=false

# LANGFLOW_API_KEY: Your Langflow API key
#   - In Langflow: Settings → API Keys → Copy your key
#   - Example: sk-abc123xyz...
LANGFLOW_API_KEY=your-langflow-api-key

# COS_COMPONENT_ID: The ID of your IBM COS File component in Langflow
#   - This is the component that receives the cos_object_key parameter
#   - Default is "IBMCOSFile" - change if you named it differently in your flow
COS_COMPONENT_ID=IBMCOSFile

# ----------------------------------------------------------------------------
# COS Configuration (REQUIRED - Your existing bucket)
# ----------------------------------------------------------------------------
# COS_BUCKET_NAME: Name of your existing IBM Cloud Object Storage bucket
#   - Example: my-documents-bucket
COS_BUCKET_NAME=your-bucket-name

# COS_REGION: Region where your bucket is located
#   - Common values: us-south, us-east, eu-gb, eu-de, jp-tok, au-syd
COS_REGION=us-south

# ----------------------------------------------------------------------------
# Event Notifications Configuration (OPTIONAL - Customize names)
# ----------------------------------------------------------------------------
# EN_INSTANCE_NAME: Name for the Event Notifications service instance
#   - This will be created by the setup script
#   - Choose any descriptive name you like
EN_INSTANCE_NAME=event-notifications-langflow

# EN_REGION: Region for Event Notifications instance
EN_REGION=us-south

# EN_PLAN: Service plan (lite is free tier)
EN_PLAN=lite

# ----------------------------------------------------------------------------
# Code Engine Configuration (OPTIONAL - Customize names)
# ----------------------------------------------------------------------------
# CE_PROJECT_NAME: Name for the Code Engine project
#   - This will be created by the setup script
#   - Choose any descriptive name you like
CE_PROJECT_NAME=langflow-triggers

# CE_FUNCTION_NAME: Name for the Code Engine function
#   - This will be created by the setup script
#   - Choose any descriptive name you like
CE_FUNCTION_NAME=cos-langflow-trigger

# CE_REGION: Region for Code Engine resources
CE_REGION=us-south

# ----------------------------------------------------------------------------
# Resource Names (OPTIONAL - Customize display names)
# ----------------------------------------------------------------------------
# These are display names for Event Notifications resources
# Choose any names you like - they're just labels

# TOPIC_NAME: Display name for the Event Notifications topic
TOPIC_NAME=New COS Files

# DESTINATION_NAME: Display name for the webhook destination
DESTINATION_NAME=Langflow Trigger Webhook

# SUBSCRIPTION_NAME: Display name for the subscription
SUBSCRIPTION_NAME=COS to Langflow